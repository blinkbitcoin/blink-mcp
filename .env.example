# Required: Blink API key with appropriate permissions
# Get your key at https://dashboard.blink.sv (Settings > API Keys)
# Permissions needed:
#   READ   — for balance, transaction, price queries
#   RECEIVE — for creating invoices
#   WRITE  — for sending payments (Lightning, on-chain, intraledger)
BLINK_API_KEY=your_blink_api_key_here

# Optional: Network (mainnet or staging, defaults to mainnet)
# Use staging for testing against https://api.staging.blink.sv
BLINK_NETWORK=mainnet
